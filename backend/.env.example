# API Configuration
PROJECT_NAME="Forest Fire Detection API"
API_V1_STR="/api/v1"

# Security Configuration
# Generate a secure secret using: openssl rand -hex 32
JWT_SECRET_KEY="replace_me_with_a_secure_random_key_in_production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
# Use SQLite for development: sqlite+aiosqlite:///./app.db
# Use PostgreSQL for production: postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL="sqlite+aiosqlite:///./app.db"

# Admin Setup
DEFAULT_ADMIN_EMAIL="admin@forestfire.org"
DEFAULT_ADMIN_USERNAME="admin"
DEFAULT_ADMIN_PASSWORD="SuperSecurePassword123!"
