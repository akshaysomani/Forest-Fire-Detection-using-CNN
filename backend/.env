# ─────────────────────────────────────────────────────────────
#  Forest Fire Detection — Backend Environment Configuration
#  Place this file at: backend/.env
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL (local) ────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Change DB_USER, DB_PASSWORD, and DB_NAME to match your local setup.
DATABASE_URL=postgresql+asyncpg://postgres:Akfire1804%3F%3F%3F@127.0.0.1:5432/Forest Fire

# ── Security ──────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Default Super Admin (seeded on first run) ─────────────────
DEFAULT_ADMIN_EMAIL=admin@forestfire.org
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=SuperSecurePassword123!

# ── CORS ──────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Storage ───────────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_BASE_DIR=./storage
